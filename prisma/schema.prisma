datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model QuoteRequest {
  id              String   @id @default(uuid())
  companyName     String
  contactEmail    String
  productInterest String?
  quantity        String?
  projectNotes    String?
  createdAt       DateTime @default(now())
}

model ContactEnquiry {
  id          String   @id @default(uuid())
  name        String
  companyName String?
  email       String
  message     String
  createdAt   DateTime @default(now())
}

model TradeApplication {
  id           String   @id @default(uuid())
  companyName  String
  contactName  String
  email        String
  phone        String?
  businessType String
  notes        String?
  createdAt    DateTime @default(now())
}

model ProcessedWebhook {
  eventId   String   @id
  createdAt DateTime @default(now())
}
